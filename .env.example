# 应用配置
APP_NAME=User Study Platform
APP_VERSION=2.0.0
DEBUG=false

# 服务器配置
HOST=0.0.0.0
PORT=8888
WORKERS=4

# 安全配置（生产环境请务必修改！）
ADMIN_PASSWORD=your-secure-password-here
SECRET_KEY=your-secret-key-here

# 数据库配置
DATABASE_URL=sqlite:///./user_study.db
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# 路径配置（通常不需要修改）
UPLOAD_FOLDER=uploads
STATIC_FOLDER=static

# 功能开关
ENABLE_CACHE=true
CACHE_TTL=300
